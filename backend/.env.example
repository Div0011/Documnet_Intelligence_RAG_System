APP_NAME=DocIntel RAG
APP_VERSION=1.0.0
ENVIRONMENT=development
LOG_LEVEL=INFO

# LLM Providers
GROQ_API_KEY=your_groq_api_key_here

# Optional: Override embedding model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# Retrieval
TOP_K_DENSE=20
TOP_K_FINAL=5
RERANK_SCORE_THRESHOLD=0.3

# Storage
DATA_DIR=../data
CHROMA_DIR=../data/chroma

# Upload limits
MAX_FILE_SIZE_MB=50
MAX_FILES_PER_UPLOAD=50

# CORS - Update with your GitHub Pages URL
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://div0011.github.io
